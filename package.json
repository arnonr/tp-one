{
  "name": "tp-one",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:server": "bun run --filter '@tp-one/server' dev",
    "dev:web": "bun run --filter '@tp-one/web' dev",
    "build": "bun run --filter '*' build",
    "db:generate": "bun run --filter '@tp-one/server' db:generate",
    "db:migrate": "bun run --filter '@tp-one/server' db:migrate",
    "db:studio": "bun run --filter '@tp-one/server' db:studio"
  }
}
